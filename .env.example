# go-jira configuration — copy to `.env` and fill in.
#   cp .env.example .env
# Loaded automatically from `.env` (override with `--env-file=path`).
# `.env` is gitignored; never commit real secrets.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Jira instance base URL. Must be https unless JIRA_INSECURE=true.
JIRA_BASE_URL=https://jira.example.com

# ---------------------------------------------------------------------------
# Authentication — pick ONE mode and fill only its variables.
# ---------------------------------------------------------------------------
# Mode 1: Bearer / Personal Access Token (recommended for CI/CD)
JIRA_TOKEN=

# Mode 2: Basic auth (username + password are required together)
# JIRA_USERNAME=
# JIRA_PASSWORD=

# Mode 3: OAuth, local dev — run `go-jira login`; the token is stored in your
# OS keyring (or an encrypted file). No env vars needed unless you override the
# embedded client credentials below.
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=

# Mode 4: OAuth, CI/CD — inject a refresh token. Jira DC rotates the refresh
# token on every refresh, so write the new one back to your secret store via
# JIRA_OAUTH_REFRESH_TOKEN_OUTPUT. See docs/oauth-usage.md.
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=
# JIRA_OAUTH_REFRESH_TOKEN=
# JIRA_OAUTH_REFRESH_TOKEN_OUTPUT=.jira-refresh-token

# Master password for the AES-256-GCM encrypted file token store, used only when
# no OS keyring is available (e.g. headless CI).
# JIRA_MASTER_PASSWORD=

# ---------------------------------------------------------------------------
# `go-jira run` action settings
# ---------------------------------------------------------------------------
# Text scanned for issue keys (git ref/tag/commit message). Required for `run`.
REF=
# Custom regex for issue-key extraction (optional; defaults to built-in pattern).
# ISSUE_FORMAT=
# Target transition/status name (e.g. Done).
# TRANSITION=
# Resolution name (e.g. Fixed).
# RESOLUTION=
# Comment to add to matched issues.
# COMMENT=
# Username to assign matched issues to.
# ASSIGNEE=
# Convert COMMENT from Markdown to Jira wiki syntax (true/1).
# MARKDOWN=false

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Skip TLS verification — NOT for production (true/1).
# JIRA_INSECURE=false
# Dump the resolved configuration on startup (true/1).
# DEBUG=false
